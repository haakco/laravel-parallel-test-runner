<?xml version="1.0" encoding="UTF-8"?>
<ruleset
    name="Laravel Parallel Test Runner focused complexity rules"
    xmlns="https://phpmd.org/xml/ruleset/1.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://phpmd.org/xml/ruleset/1.0.0 https://phpmd.org/xml/ruleset_xml_schema.xsd"
>
    <description>
        Focused complexity checks for package source code.
    </description>

    <exclude-pattern>*/vendor/*</exclude-pattern>

    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="10" />
        </properties>
    </rule>

    <rule ref="rulesets/codesize.xml/NPathComplexity">
        <properties>
            <property name="minimum" value="200" />
        </properties>
    </rule>
</ruleset>
